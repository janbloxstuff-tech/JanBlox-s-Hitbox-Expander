local function refreshUI()
	toggleHitboxesBtn.Text = "Toggle Hitboxes: " .. (state.hitboxesEnabled and "ON" or "OFF")
	playerHitboxBtn.Text = "Toggle Player Hitbox: " .. (state.playerHitbox and "ON" or "OFF")
	npcHitboxBtn.Text = "Toggle NPC Hitbox: " .. (state.npcHitbox and "ON" or "OFF")
	forceFieldBtn.Text = "Toggle ForceField: " .. (state.forceFieldHitbox and "ON" or "OFF")

	espPlayerBtn.Text = "Toggle Player ESP: " .. (state.playerESP and "ON" or "OFF")
	espNpcBtn.Text = "Toggle NPC ESP: " .. (state.npcESP and "ON" or "OFF")
	highlightBtn.Text = "Toggle Highlight: " .. (state.highlightESP and "ON" or "OFF")
	boxBtn.Text = "Toggle 2D Boxes: " .. (state.boxESP and "ON" or "OFF")

	sizeLabel.Text = "Size: " .. tostring(state.size) .. " / " .. tostring(MAX_SIZE)
	speedLabel.Text = "WalkSpeed: " .. tostring(state.walkSpeed)
	jumpLabel.Text = "JumpPower: " .. tostring(state.jumpPower)
	layDownBtn.Text = "Lay Down: " .. (state.layDown and "ON" or "OFF")

	updateCanvas()
end

local function applyMovementToCurrentCharacter()
	local character = LocalPlayer.Character
	if character then
		applyLocalMovement(character)
	end
end

local function setMainVisible(visible)
	state.guiVisible = visible
	main.Visible = visible
end

