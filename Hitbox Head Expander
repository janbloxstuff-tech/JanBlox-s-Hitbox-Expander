end

local function shouldShowCategory(info)
	if info.isPlayer then
		return state.playerESP or state.highlightESP or state.boxESP
	end
	return state.npcESP or state.highlightESP or state.boxESP
end

local function shouldShowNameBillboard(info)
	if info.isPlayer then
		return state.playerESP
	end
	return state.npcESP
end

local function shouldApplyHitbox(model, info)
	if not state.hitboxesEnabled then
		return false
	end

	if info.isPlayer then
		if not state.playerHitbox then
			return false
		end
		if not info.player or not isEnemyPlayer(info.player) then
			return false
		end
	else
		if not state.npcHitbox then
			return false
		end
	end

	if hasForceField(model) and not state.forceFieldHitbox then
		return false
	end

	return true
end

local function updateVisuals(model)
	local info = modelInfo[model]
	if not info then
		return
	end

	local humanoid = info.humanoid or getHumanoid(model)
	info.humanoid = humanoid

	local head = info.head or getHead(model)
	local root = getRootPart(model)

	if not shouldShowCategory(info) then
		applyHumanoidNameVisibility(model, false)
		destroyEsp(model)
		destroyHighlight(model)
		destroyBox(model)
		return
	end

	applyHumanoidNameVisibility(model, true)

	local dead = isDeadHumanoid(humanoid)
	local showName = shouldShowNameBillboard(info)

	local nameText
	if info.isPlayer and info.player then
		nameText = info.player.Name
	else
		nameText = model.Name
	end

	local healthText = "Dead"
	if not dead and humanoid then
		local currentHealth = math.max(0, math.floor(humanoid.Health + 0.5))
		local maxHealth = math.max(1, math.floor(humanoid.MaxHealth + 0.5))
		healthText = ("Health: %d/%d"):format(currentHealth, maxHealth)
	end

	if showName and head then
		local gui = espCache[model]
		if not gui or not gui.Parent then
			gui, info.nameLabel, info.hpLabel = makeBillboard(model, head, nameText, healthText)
			espCache[model] = gui
		else
			gui.Adornee = head
			gui.Parent = head
			if info.nameLabel then
				info.nameLabel.Text = nameText
			end
			if info.hpLabel then
				info.hpLabel.Text = healthText
			end
		end
	else
		destroyEsp(model)
	end

	if dead then
		destroyHighlight(model)
		destroyBox(model)
		return
	end

	if state.highlightESP then
		if not info.highlight or not info.highlight.Parent then
			info.highlight = makeHighlight(model)
		else
			info.highlight.Adornee = model
		end
	else
		destroyHighlight(model)
	end

	if state.boxESP and root then
		if not info.box or not info.box.Parent then
			info.box = makeBox(model)
		else
			info.box.Adornee = root
			info.box.Size = model:GetExtentsSize()
		end
	else
		destroyBox(model)
	end
end

local function applyModelEffects(model)
	local info = modelInfo[model]
	if not info then
		return
	end

	local head = info.head or getHead(model)
	info.head = head
	info.humanoid = info.humanoid or getHumanoid(model)

	if head then
		if shouldApplyHitbox(model, info) then
			applyHitboxToHead(head)
		else
			restorePart(head)
		end
	end

	updateVisuals(model)
end

local function watchModel(model, isPlayer, player)
	if not model or modelInfo[model] then
		return
	end

	local info = {
		isPlayer = isPlayer,
		player = player,
		head = nil,
		humanoid = getHumanoid(model),
		baseHipHeight = nil,
		humanoidNameCache = nil,
		highlight = nil,
		box = nil,
		connections = {},
		nameLabel = nil,
		hpLabel = nil,
	}

	modelInfo[model] = info

	local function refreshHead()
		local head = getHead(model)
		if head and info.head ~= head then
			if info.head then
				restorePart(info.head)
			end
			info.head = head
		end
		applyModelEffects(model)
	end

	table.insert(info.connections, model.ChildAdded:Connect(function(child)
		if child.Name == "Head" and child:IsA("BasePart") then
			refreshHead()
		elseif child:IsA("Humanoid") then
			info.humanoid = child
			info.baseHipHeight = info.baseHipHeight or child.HipHeight

			table.insert(info.connections, child.HealthChanged:Connect(function()
				updateVisuals(model)
			end))

			table.insert(info.connections, child.Died:Connect(function()
				updateVisuals(model)
			end))

			if not isPlayer and state.npcHitbox then
				applyModelEffects(model)
			end
		elseif child:IsA("ForceField") then
			applyModelEffects(model)
		end
	end))

	table.insert(info.connections, model.ChildRemoved:Connect(function(child)
		if child:IsA("ForceField") then
			applyModelEffects(model)
		end
	end))

	table.insert(info.connections, model.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			cleanupModel(model)
		end
	end))

	local humanoid = info.humanoid
	if humanoid then
		info.baseHipHeight = info.baseHipHeight or humanoid.HipHeight

		table.insert(info.connections, humanoid.HealthChanged:Connect(function()
			updateVisuals(model)
		end))

		table.insert(info.connections, humanoid.Died:Connect(function()
			updateVisuals(model)
		end))
	end

	refreshHead()
end

local function setupPlayer(player)
	if trackedPlayers[player] then
		return
	end

	trackedPlayers[player] = true

	player.CharacterAdded:Connect(function(character)
		task.spawn(function()
			watchModel(character, true, player)

			local head = character:WaitForChild("Head", 6)
			if head and head:IsA("BasePart") then
				local info = modelInfo[character]
				if info then
					info.head = head
					applyModelEffects(character)
				end
			end

			applyLayoutForCharacter(character)
		end)
	end)

	player.CharacterRemoving:Connect(function(character)
		cleanupModel(character)
	end)

	if player.Character then
		task.spawn(function()
			watchModel(player.Character, true, player)

			local head = player.Character:WaitForChild("Head", 6)
			if head and head:IsA("BasePart") then
				local info = modelInfo[player.Character]
				if info then
					info.head = head
					applyModelEffects(player.Character)
				end
			end

			applyLayoutForCharacter(player.Character)
		end)
	end
end

local function setupNPCModel(model)
	if trackedNPCs[model] then
		return
	end

	if Players:GetPlayerFromCharacter(model) then
		return
	end

	local humanoid = getHumanoid(model)
	if not humanoid then
		return
	end

	trackedNPCs[model] = true
	watchModel(model, false, nil)
end

local function refreshAll()
	for player, _ in pairs(trackedPlayers) do
		if player and player.Character then
			local info = modelInfo[player.Character]
			if info then
				info.head = getHead(player.Character) or info.head
				info.humanoid = info.humanoid or getHumanoid(player.Character)
				applyModelEffects(player.Character)
				if player == LocalPlayer then
					applyLayoutForCharacter(player.Character)
				end
			end
		end
	end

	for model, _ in pairs(trackedNPCs) do
		if model and model.Parent then
			local info = modelInfo[model]
			if info then
				info.head = getHead(model) or info.head
				info.humanoid = info.humanoid or getHumanoid(model)
				applyModelEffects(model)
			end
		end
	end
end

for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

Players.PlayerAdded:Connect(setupPlayer)

for _, inst in ipairs(Workspace:GetDescendants()) do
	if inst:IsA("Humanoid") and inst.Parent and inst.Parent:IsA("Model") then
		if not Players:GetPlayerFromCharacter(inst.Parent) then
			setupNPCModel(inst.Parent)
		end
	end
end

Workspace.DescendantAdded:Connect(function(inst)
	if inst:IsA("Humanoid") and inst.Parent and inst.Parent:IsA("Model") then
		if not Players:GetPlayerFromCharacter(inst.Parent) then
			setupNPCModel(inst.Parent)
		end
	end
end)

Players.PlayerRemoving:Connect(function(player)
	if player.Character then
		cleanupModel(player.Character)
	end
	trackedPlayers[player] = nil
end)

