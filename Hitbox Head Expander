if isMobile() then
	local toggleButton = Instance.new("TextButton")
	toggleButton.Name = "OpenCloseButton"
	toggleButton.Size = UDim2.new(0, 120, 0, 40)
	toggleButton.Position = UDim2.new(0, 16, 0.65, 0)
	toggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
	toggleButton.BorderSizePixel = 0
	toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggleButton.Font = Enum.Font.GothamBold
	toggleButton.TextSize = 15
	toggleButton.Text = "Open / Close"
	toggleButton.Parent = screenGui

	local toggleCorner = Instance.new("UICorner")
	toggleCorner.CornerRadius = UDim.new(0, 8)
	toggleCorner.Parent = toggleButton

	local toggleStroke = Instance.new("UIStroke")
	toggleStroke.Thickness = 1
	toggleStroke.Transparency = 0.4
	toggleStroke.Parent = toggleButton

	local mobileDrag = false
	local dragStartPos
	local dragStartButtonPos

	toggleButton.Active = true
	toggleButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			mobileDrag = true
			dragStartPos = input.Position
			dragStartButtonPos = toggleButton.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					mobileDrag = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if not mobileDrag then
			return
		end

		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStartPos
			toggleButton.Position = UDim2.new(
				dragStartButtonPos.X.Scale,
				dragStartButtonPos.X.Offset + delta.X,
				dragStartButtonPos.Y.Scale,
				dragStartButtonPos.Y.Offset + delta.Y
			)
		end
	end)

	toggleButton.MouseButton1Click:Connect(function()
		setMainVisible(not main.Visible)
	end)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if input.KeyCode == Enum.KeyCode.K then
		setMainVisible(not main.Visible)
	elseif input.KeyCode == Enum.KeyCode.L then
		state.hitboxesEnabled = not state.hitboxesEnabled
		refreshUI()
		refreshAll()
	end
end)

