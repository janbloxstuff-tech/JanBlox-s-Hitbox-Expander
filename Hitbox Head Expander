local MIN_SIZE = 1
local MAX_SIZE = 20
local STEP_SIZE = 1

local state = {
	playerHitbox = false,
	npcHitbox = false,
	playerESP = false,
	npcESP = false,
	size = 4,
}

_G.HeadSize = state.size
_G.RootSize = state.size

local originalParts = {}
local trackedPlayers = {}
local trackedNPCs = {}
local modelInfo = {}
local espCache = {}

local function isEnemyPlayer(player)
	if not player or player == LocalPlayer then
		return false
	end

	if LocalPlayer.Team ~= nil and player.Team ~= nil and LocalPlayer.Team == player.Team then
		return false
	end

	return true
end

local function clampSize(value)
	return math.clamp(value, MIN_SIZE, MAX_SIZE)
end

local function getHead(model)
	if not model then
		return nil
	end
	local head = model:FindFirstChild("Head")
	if head and head:IsA("BasePart") then
		return head
	end
	return nil
end

local function getHumanoid(model)
	if not model then
		return nil
	end
	return model:FindFirstChildOfClass("Humanoid")
end

local function saveOriginal(part)
	if originalParts[part] then
		return
	end

	originalParts[part] = {
		Size = part.Size,
		Anchored = part.Anchored,
		CanCollide = part.CanCollide,
		Massless = part.Massless,
		Transparency = part.Transparency,
		CastShadow = part.CastShadow,
	}
end

local function restorePart(part)
	local data = originalParts[part]
	if not data then
		return
	end

	if part and part.Parent then
		pcall(function()
			part.Size = data.Size
			part.Anchored = data.Anchored
			part.CanCollide = data.CanCollide
			part.Massless = data.Massless
			part.Transparency = data.Transparency
			part.CastShadow = data.CastShadow
		end)
	end

	originalParts[part] = nil
end

local function destroyEsp(model)
	local gui = espCache[model]
	if gui then
		gui:Destroy()
		espCache[model] = nil
	end
end

local function cacheHumanoidNameState(humanoid)
	local data = {}

	pcall(function()
		data.DisplayDistanceType = humanoid.DisplayDistanceType
	end)

	pcall(function()
		data.NameDisplayDistance = humanoid.NameDisplayDistance
	end)

	pcall(function()
		data.NameOcclusion = humanoid.NameOcclusion
	end)

	return data
end

local function applyHumanoidNameVisibility(model, hidden)
	local info = modelInfo[model]
	if not info then
		return
	end

	local humanoid = info.humanoid or getHumanoid(model)
	if not humanoid then
		return
	end

	if not info.humanoidNameCache then
		info.humanoidNameCache = cacheHumanoidNameState(humanoid)
	end

	if hidden then
		pcall(function()
			humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
		end)

		pcall(function()
			humanoid.NameDisplayDistance = 0
		end)
	else
		local cache = info.humanoidNameCache
		if cache then
			pcall(function()
				if cache.DisplayDistanceType ~= nil then
					humanoid.DisplayDistanceType = cache.DisplayDistanceType
				end
			end)

			pcall(function()
				if cache.NameDisplayDistance ~= nil then
					humanoid.NameDisplayDistance = cache.NameDisplayDistance
				end
			end)

			pcall(function()
				if cache.NameOcclusion ~= nil then
					humanoid.NameOcclusion = cache.NameOcclusion
				end
			end)
		end
	end
end

local function cleanupModel(model)
	if not modelInfo[model] then
		return
	end

	local info = modelInfo[model]

	if info.head then
		restorePart(info.head)
	end

	applyHumanoidNameVisibility(model, false)
	destroyEsp(model)

	if info.connections then
		for _, conn in ipairs(info.connections) do
			if conn then
				conn:Disconnect()
			end
		end
	end

	modelInfo[model] = nil
	trackedPlayers[model] = nil
	trackedNPCs[model] = nil
end

local function applyHitboxToHead(head)
	if not head or not head:IsA("BasePart") then
		return
	end

	saveOriginal(head)

	local sizeValue = clampSize(state.size)

	head.Anchored = false
	head.CanCollide = false
	head.Massless = true
	head.Transparency = 0.5
	head.Size = Vector3.new(sizeValue, sizeValue, sizeValue)
end

